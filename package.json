{
  "name": "networkplus-quiz",
  "version": "7.35.0",
  "private": true,
  "scripts": {
    "test:uat": "node tests/uat.js",
    "test:e2e": "npx playwright test --project=chromium",
    "test:e2e:all": "npx playwright test",
    "test:webkit": "npx playwright test --project=webkit",
    "test:mobile-safari": "npx playwright test --project=mobile-safari",
    "test:ios": "npx playwright test --project=webkit --project=mobile-safari",
    "test:fidelity": "npx playwright test --project=cert-ios-fidelity",
    "test": "npm run test:uat && npm run test:e2e",
    "ios:www": "rm -rf capacitor-www && cp -R mockups capacitor-www && cp capacitor-www/cert-ios-app.html capacitor-www/index.html",
    "ios:add": "npm run ios:www && npx cap add ios --packagemanager SPM",
    "ios:sync": "npm run ios:www && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:run": "npm run ios:sync && npx cap run ios",
    "serve": "npx serve . -l 3131 -s",
    "serve:dist": "npx serve dist -l 3132 -s",
    "build": "node scripts/build.js",
    "build:test": "node tests/build.test.js",
    "bump": "node scripts/bump-version.js",
    "stage": "node scripts/stage.js",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^7.6.6",
    "@capacitor/ios": "^7.6.6",
    "@playwright/test": "^1.49.0",
    "esbuild": "^0.28.0",
    "serve": "^14.2.0"
  }
}
