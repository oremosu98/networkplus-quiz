{
  "name": "networkplus-quiz",
  "version": "4.99.36",
  "private": true,
  "scripts": {
    "test:uat": "node tests/uat.js",
    "test:e2e": "npx playwright test --project=chromium",
    "test:e2e:all": "npx playwright test",
    "test:webkit": "npx playwright test --project=webkit",
    "test:mobile-safari": "npx playwright test --project=mobile-safari",
    "test:ios": "npx playwright test --project=webkit --project=mobile-safari",
    "test": "npm run test:uat && npm run test:e2e",
    "serve": "npx serve . -l 3131 -s",
    "bump": "node scripts/bump-version.js",
    "stage": "node scripts/stage.js",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "serve": "^14.2.0"
  }
}
