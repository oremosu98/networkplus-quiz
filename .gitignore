.DS_Store
# .claude/ holds local Claude Code state (launch.json, sessions). Skills
# are project-level and DO ship — exception them in.
.claude/*
!.claude/skills/

# Third-party skills installed via `npx skills add <owner>/<repo>` — personal
# dev tooling, NOT CertAnvil app code. The CLI drops real content in .agents/
# and symlinks each skill into .claude/skills/. First-party project skills
# (e.g. .claude/skills/review-feature/) DO ship; third-party installed ones
# never enter this brand-critical repo. Add a symlink line per new install.
.agents/
skills-lock.json
.claude/skills/impeccable
.claude/skills/emil-design-eng

.vercel

# Dependencies
node_modules/

# Build output — minified production bundle, regenerated by `npm run build`
dist/

# Playwright
test-results/
playwright-report/
blob-report/

# Session handoffs from deleted chats — may contain leaked tokens/keys that
# were pasted into prompts. Keep on disk locally but never commit.
AI_QUIZ_HANDOFF.md
*_HANDOFF.md

# Claude Design prototype bundles — local reference only, not shipped
.design-reference/

# brainstorming visual companion (transient session files)
.superpowers/

# graphify code-map output — regenerated locally (auto-rebuilt by the
# post-commit/post-merge hooks). ~3MB of graph.json/html/report + cache;
# local-only, never committed. The .graphifyignore config IS tracked so the
# code-only build is reproducible. glabel.txt is a transient naming log.
graphify-out/
glabel.txt

# Sec-P4 / L5 — secret-bearing files must never enter git history. No secrets
# have leaked to date (audit Phase 0); these patterns are a forward guard
# against an accidental commit of env files, private keys, or a secrets dir.
.env
.env.*
*.key
*.pem
secrets/
