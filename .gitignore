.DS_Store
# .claude/ holds local Claude Code state (launch.json, sessions). Skills
# are project-level and DO ship — exception them in.
.claude/*
!.claude/skills/

# Third-party skills installed via `npx skills add <owner>/<repo>` — personal
# dev tooling, NOT CertAnvil app code. The CLI drops real content in .agents/
# and symlinks each skill into .claude/skills/. First-party project skills
# (e.g. .claude/skills/review-feature/) DO ship; third-party installed ones
# never enter this brand-critical repo. Add a symlink line per new install.
.agents/
skills-lock.json
.claude/skills/impeccable
.claude/skills/emil-design-eng

.vercel

# Dependencies
node_modules/

# Playwright
test-results/
playwright-report/
blob-report/

# Session handoffs from deleted chats — may contain leaked tokens/keys that
# were pasted into prompts. Keep on disk locally but never commit.
AI_QUIZ_HANDOFF.md
*_HANDOFF.md

# Claude Design prototype bundles — local reference only, not shipped
.design-reference/

# brainstorming visual companion (transient session files)
.superpowers/
